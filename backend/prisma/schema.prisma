// prisma/schema.prisma
generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
  interface            = "sync"  // <--- ADD THIS LINE

}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Task {
  id       Int    @id @default(autoincrement())
  content  String
  category String
  createdAt DateTime @default(now()) // Add this line
}
